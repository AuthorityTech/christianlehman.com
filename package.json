{
  "name": "christianlehman-com",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "seo:guard": "node scripts/validate-seo-metadata.mjs",
    "seo:report": "node scripts/report-seo-repairs.mjs",
    "content:manifest": "node scripts/validate-content-manifest.mjs",
    "content:links": "node scripts/validate-internal-links.mjs",
    "ontology:guard": "node scripts/guard-ontology-schema.mjs",
    "ontology:graph": "node scripts/validate-ontology-graph.mjs",
    "prebuild": "npm run seo:report && npm run content:manifest && npm run content:links && npm run seo:guard && npm run ontology:guard && npm run ontology:graph && node scripts/generate-og-images.mjs",
    "dev": "next dev --hostname 127.0.0.1",
    "build": "npm run machine:parity && next build && node scripts/crawl-guard.mjs",
    "start": "next start",
    "lint": "next lint",
    "machine:parity": "node scripts/validate-machine-view-parity.mjs",
    "smoke": "bash scripts/smoke-check.sh",
    "gsc:check": "bash scripts/gsc-check.sh",
    "vercel:status": "bash scripts/vercel-status.sh",
    "indexnow": "node scripts/ping-indexnow.mjs",
    "indexnow:all": "node scripts/ping-indexnow.mjs --all",
    "indexing:wait": "node scripts/wait-for-live-sitemap.mjs",
    "indexing:google-sitemap": "node scripts/submit-google-sitemap.mjs",
    "indexing:submit": "npm run indexing:wait && npm run indexnow:all && npm run indexing:google-sitemap"
  },
  "dependencies": {
    "@editorialkit/schema": "file:packages/editorialkit-schema-1.2.0.tgz",
    "gray-matter": "^4.0.3",
    "next": "^15.5.18",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "remark": "^15.0.1",
    "remark-gfm": "^4.0.1",
    "remark-html": "^16.0.1"
  },
  "devDependencies": {
    "@fontsource/inter": "^5.2.8",
    "@resvg/resvg-js": "^2.6.2",
    "@tailwindcss/typography": "^0.5.15",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.1.6",
    "postcss": "^8.4.49",
    "satori": "^0.19.2",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "vercel": "^50.32.5"
  }
}
